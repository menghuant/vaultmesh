{
  "name": "@vaultmesh/server",
  "version": "0.1.0",
  "description": "VaultMesh WebSocket sync server",
  "main": "./dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@vaultmesh/auth": "workspace:*",
    "@vaultmesh/core": "workspace:*",
    "ws": "^8.17.0",
    "yjs": "^13.6.0",
    "y-websocket": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
