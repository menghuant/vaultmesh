<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.vaultmesh.daemon</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/vaultmesh</string>
    <string>daemon</string>
    <string>start</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>
  <key>StandardOutPath</key>
  <string>/tmp/vaultmesh-daemon.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/vaultmesh-daemon.err.log</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
