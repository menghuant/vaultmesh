{
  "name": "vaultmesh",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native Markdown vault team sync service",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "workspaces": [
    "packages/*",
    "server",
    "plugin-obsidian",
    "plugin-vscode",
    "cli",
    "mcp-server",
    "web"
  ]
}
