# VaultMesh Server Configuration
# Copy to .env and update values

# PostgreSQL connection string
VAULTMESH_DB_URL=postgresql://vaultmesh:vaultmesh@localhost:5432/vaultmesh

# JWT signing secret (generate with: openssl rand -base64 32)
VAULTMESH_JWT_SECRET=change-me-in-production

# File storage directory
VAULTMESH_STORAGE_PATH=./data

# Server port
VAULTMESH_PORT=4000

# Public-facing server URL (used in invite tokens)
# Must be reachable by team members (public IP, domain, or VPN)
VAULTMESH_SERVER_URL=http://localhost:4000

# Log level: debug | info | warn | error
VAULTMESH_LOG_LEVEL=info
